{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/css/*", "/js/*", "*.css", "*.js", "*.html", "*.ico", "*.png", "*.jpg", "*.svg"]
  },
  "routes": [
    {
      "route": "/api/*",
      "allowedRoles": ["anonymous"]
    }
  ],
  "platform": {
    "apiRuntime": "node:18"
  }
}
